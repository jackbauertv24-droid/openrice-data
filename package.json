{
  "name": "openrice-scraper",
  "version": "1.0.0",
  "description": "Node.js web scraper for JavaScript-heavy e-commerce websites",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "scrape": "tsx src/index.ts",
    "schedule": "tsx src/index.ts --schedule",
    "build": "tsc",
    "clean": "rm -rf output/*.json",
    "test:select": "tsx src/index.ts --test-selectors"
  },
  "keywords": [
    "scraper",
    "playwright",
    "e-commerce",
    "web-scraping"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.40.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.6.0"
  }
}
